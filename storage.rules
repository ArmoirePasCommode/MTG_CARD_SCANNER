rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Uploads utilisateur - accès restreint par userId
    match /uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Note: Ces règles ne sont pas strictement nécessaires si vous utilisez uniquement l'API Cloud Functions
    // car le SDK Admin bypass les règles. Mais c'est une bonne pratique de sécurité.
  }
}


