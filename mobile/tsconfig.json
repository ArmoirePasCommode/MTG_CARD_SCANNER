{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": false,
    "noFallthroughCasesInSwitch": true,
    "allowJs": false,
    "skipLibCheck": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["./src/components/*"],
      "@screens/*":    ["./src/screens/*"],
      "@hooks/*":      ["./src/hooks/*"],
      "@services/*":   ["./src/services/*"],
      "@context/*":    ["./src/context/*"],
      "@utils/*":      ["./src/utils/*"],
      "@navigation/*": ["./src/navigation/*"],
      "expo-file-system": ["./node_modules/expo-file-system/build/index.d.ts"],
      "expo-file-system/next": ["./node_modules/expo-file-system/build/index.d.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "eslint.config.js"
  ]
}
